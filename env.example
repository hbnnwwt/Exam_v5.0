# AI Provider Keys - 生产部署用
# 将此文件复制为 .env 后填入真实密钥
# 优先级：ENV > DB > JSON模板

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_API_FORMAT=anthropic

# ModelScope
MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn
MODELSCOPE_MODEL=qwen3.5-397b

# 硅基流动
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-8B

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
GEMINI_MODEL=gemini-2.0-flash

# 默认 Provider（填 provider id，如 minimax、siliconflow）
DEFAULT_PROVIDER=

# 数据库路径（可选，默认使用 assets/data/interview_system.db）
# DATABASE_PATH=backend/assets/data/interview_system.db
